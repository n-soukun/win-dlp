<Page x:Class="otosun.Views.ProgressPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:otosun.Views"
      xmlns:viewmodels="clr-namespace:otosun.ViewModels"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProgressPage"
      KeepAlive="True"
      SizeChanged="Page_SizeChanged">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Page.DataContext>
        <viewmodels:ProgressPageViewModel />
    </Page.DataContext>

    <Grid Margin="40,30,40,40" VerticalAlignment="Stretch" MaxWidth="1000" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ステータスメッセージ (プログレスバーの上) -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBlock Text="{Binding Download.StatusText}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <ui:ProgressRing Grid.Column="1"
                             IsIndeterminate="True"
                             Height="20"
                             Width="20"
                             VerticalAlignment="Center"
                             Margin="10,0,0,0"
                             Visibility="{Binding Download.IsDownloading, Converter={StaticResource BoolToVis}}" />
        </Grid>

        <!-- プログレスバー -->
        <ProgressBar Grid.Row="1"
                     Height="8"
                     Minimum="0"
                     Maximum="100"
                     Value="{Binding Download.ProgressValue}"
                     IsIndeterminate="{Binding Download.IsProgressIndeterminate}"
                     Margin="0,5,0,15" />

        <!-- スクロール不可のログ (プログレスバーの下、上部フェードアウト) -->
        <Grid Grid.Row="2" Margin="0,10,0,10" VerticalAlignment="Stretch" ClipToBounds="True">
            <TextBox Name="LogTextBox"
                     Text="{Binding Download.LogText, Mode=OneWay}"
                     IsReadOnly="True"
                     IsHitTestVisible="False"
                     BorderThickness="0"
                     Background="Transparent"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Hidden"
                     VerticalAlignment="Stretch"
                     FontFamily="Consolas"
                     FontSize="12"
                     Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                     TextChanged="LogTextBox_TextChanged" />
        </Grid>

        <!-- キャンセルボタン (ページ下部) -->
        <Grid Grid.Row="3" Margin="0,20,0,0">
            <ui:Button Content="ダウンロードをキャンセル"
                       Appearance="Secondary"
                       HorizontalAlignment="Center"
                       Height="40"
                       Width="220"
                       Command="{Binding Download.CancelCommand}"
                       Icon="{ui:SymbolIcon Dismiss24}" />
        </Grid>
    </Grid>
</Page>
