<Page x:Class="otosun.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:otosun.Views"
      xmlns:viewmodels="clr-namespace:otosun.ViewModels"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="SettingsPage"
      Loaded="Page_Loaded">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Page.DataContext>
        <viewmodels:SettingsPageViewModel x:Name="ViewModel" />
    </Page.DataContext>

    <Grid MaxWidth="1000" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ヘッダー -->
        <Border Grid.Row="0" Padding="30,24,30,12">
            <TextBlock Text="設定"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
        </Border>

        <!-- メインコンテンツ -->
        <StackPanel Grid.Row="1"
                    Margin="30,0,30,20">

                <!-- 専用ツール環境のセクションヘッダー -->
                <TextBlock Text="依存関係"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,4,0,10" />

                <!-- yt-dlp -->
                <ui:Card Padding="14" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="yt-dlp" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="{Binding YtDlpVersion}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                        <ui:Button Grid.Column="1" Content="最新版をインストール" Command="{Binding UpdateYtDlpCommand}" Appearance="Secondary" Icon="{ui:SymbolIcon ArrowDownload24}" />
                    </Grid>
                </ui:Card>

                <!-- Deno -->
                <ui:Card Padding="14" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Deno" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="{Binding DenoVersion}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                        <ui:Button Grid.Column="1" Content="最新版をインストール" Command="{Binding UpdateDenoCommand}" Appearance="Secondary" Icon="{ui:SymbolIcon ArrowDownload24}" />
                    </Grid>
                </ui:Card>

                <!-- FFmpeg -->
                <ui:Card Padding="14" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="FFmpeg" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="{Binding FfmpegVersion}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                        <ui:Button Grid.Column="1" Content="最新版をインストール" Command="{Binding UpdateFfmpegCommand}" Appearance="Secondary" Icon="{ui:SymbolIcon ArrowDownload24}" />
                    </Grid>
                </ui:Card>

                <!-- ダウンロード設定セクション -->
                <TextBlock Text="ダウンロード設定"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,20,0,10" />

                <ui:Card Padding="14" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBlock Text="保存先フォルダ" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="{Binding DownloadFolderPath}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:Button Content="変更"
                                   Command="{Binding ChangeFolderCommand}"
                                   Appearance="Secondary"
                                   Icon="{ui:SymbolIcon Edit24}" Margin="0,0,8,0" />
                            <ui:Button Content="フォルダーを開く" 
                                       Command="{Binding OpenFolderCommand}"
                                       Appearance="Secondary" 
                                       Icon="{ui:SymbolIcon FolderOpen24}" />
                        </StackPanel>
                    </Grid>
                </ui:Card>

                <!-- 履歴のクリア -->
                <ui:Card Padding="14" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBlock Text="ダウンロード履歴のクリア" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="保存された動画のダウンロード履歴を一括で消去します。（保存した動画ファイル自体は削除されません）" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                        <ui:Button Grid.Column="1" Content="履歴をクリア" Command="{Binding ClearHistoryCommand}" Appearance="Secondary" Icon="{ui:SymbolIcon Delete24}" VerticalAlignment="Center" />
                    </Grid>
                </ui:Card>

                <!-- 更新進捗バー -->
                <Grid Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"
                      Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:ProgressRing IsIndeterminate="True" Height="16" Width="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding ProgressText}" Grid.Column="1" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                </Grid>

                <!-- このアプリについてセクションヘッダー -->
                <TextBlock Text="このアプリについて"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,24,0,10" />

                <!-- アプリ情報 -->
            <ui:CardExpander ContentPadding="0"
                             Icon="{ui:ImageIcon 'pack://application:,,,/Assets/otosun_128.png', Width=35, Height=35}">
                <ui:CardExpander.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBlock Grid.Row="0"
                                      Grid.Column="0"
                                      FontTypography="Body"
                                      Text="WinDLP" />
                        <ui:TextBlock Grid.Row="1"
                                      Grid.Column="0"
                                      Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                      Text="© 2026 n-soukun" />
                        <TextBlock Grid.Row="0"
                                   Grid.RowSpan="2"
                                   Grid.Column="1"
                                   Margin="0,0,16,0"
                                   VerticalAlignment="Center"
                                   Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                   Text="{Binding AppVersion, Mode=OneWay}" />
                    </Grid>
                </ui:CardExpander.Header>
                <StackPanel>
                    <Grid Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="作者" />
                        <TextBlock Grid.Column="1"
                                   Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                   Text="n-soukun" />
                    </Grid>
                    <ui:Anchor Margin="0"
                               Padding="16"
                               HorizontalAlignment="Stretch"
                               HorizontalContentAlignment="Stretch"
                               Background="Transparent"
                               BorderThickness="0,1,0,0"
                               CornerRadius="0"
                               NavigateUri="https://wpfui.lepo.co">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Webページ" />
                            <ui:SymbolIcon Grid.Column="1"
                                           Symbol="Link24" />
                        </Grid>
                    </ui:Anchor>
                    <ui:Anchor Margin="0"
                               Padding="16"
                               HorizontalAlignment="Stretch"
                               HorizontalContentAlignment="Stretch"
                               Background="Transparent"
                               BorderThickness="0,1,0,0"
                               CornerRadius="0"
                               NavigateUri="https://github.com/n-soukun/win-dlp">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Githubリポジトリ" />
                            <ui:SymbolIcon Grid.Column="1"
                                           Symbol="Link24" />
                        </Grid>
                    </ui:Anchor>
                </StackPanel>
            </ui:CardExpander>

        </StackPanel>
    </Grid>
</Page>
