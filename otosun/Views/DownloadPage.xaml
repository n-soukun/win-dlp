<Page x:Class="otosun.Views.DownloadPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:otosun.Views"
      xmlns:viewmodels="clr-namespace:otosun.ViewModels"
      xmlns:services="clr-namespace:otosun.Services"
      mc:Ignorable="d"
      d:DesignHeight="600"
      d:DesignWidth="800"
      Title="DownloadPage"
      KeepAlive="True">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Page.DataContext>
        <viewmodels:DownloadPageViewModel />
    </Page.DataContext>

    <Grid MaxWidth="1000" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ヘッダー -->
        <Border Grid.Row="0"
                Padding="30,24,30,12">
            <TextBlock Text="動画のダウンロード"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
        </Border>
        <Border Grid.Row="1"
                Padding="30,0,30,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="15" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- URL入力カード -->
                    <ui:Card Grid.Row="0"
                             Padding="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="15" />
                                <ColumnDefinition Width="110" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="15" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.ColumnSpan="3"
                                       Text="動画のURLを入力"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                            <Grid Grid.Row="1"
                                  Grid.Column="0">
                                <ui:TextBox Name="UrlTextBox"
                                            IsEnabled="{Binding Download.IsNotVerifyingUrl}"
                                            Text="{Binding Download.UrlText, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="https://www.youtube.com/watch?v=..."
                                            Icon="{ui:SymbolIcon Link24}"
                                            ClearButtonEnabled="True" />
                            </Grid>

                            <ui:Button Name="PasteButton"
                                       Grid.Row="1"
                                       Grid.Column="2"
                                       Width="110"
                                       Height="36"
                                       Content="貼り付け"
                                       IsEnabled="{Binding Download.IsNotVerifyingUrl}"
                                       Command="{Binding Download.PasteCommand}"
                                       Icon="{ui:SymbolIcon Clipboard24}"
                                       Appearance="Secondary" />

                            <Grid Grid.Row="3"
                                  Grid.ColumnSpan="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="15" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                    <!-- 保存形式 of 選択 -->
                                    <StackPanel Grid.Column="0"
                                                Orientation="Horizontal">
                                        <TextBlock Text="保存形式:"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,15,0"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                        <RadioButton Content="MP4 (動画 + 音声)"
                                                     IsEnabled="{Binding Download.IsNotVerifyingUrl}"
                                                     IsChecked="{Binding Download.IsMp4, Mode=TwoWay}"
                                                     Margin="0,0,20,0" />
                                        <RadioButton Content="MP3 (音声のみ)"
                                                     IsEnabled="{Binding Download.IsNotVerifyingUrl}"
                                                     IsChecked="{Binding Download.IsMp3, Mode=TwoWay}" />
                                    </StackPanel>

                                    <!-- 保存ボタンと検証中表示 -->
                                    <Grid Grid.Column="3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- 検証中表示 -->
                                        <StackPanel Grid.Column="0" 
                                                    Orientation="Horizontal" 
                                                    Margin="0,0,15,0"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding Download.IsVerifyingUrl, Converter={StaticResource BoolToVis}}">
                                            <ui:ProgressRing IsIndeterminate="True" 
                                                             Height="16" Width="16" 
                                                             Margin="0,0,8,0" 
                                                             VerticalAlignment="Center"/>
                                            <TextBlock Text="URL検証中..." 
                                                       VerticalAlignment="Center" 
                                                       FontSize="13" 
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>

                                        <ui:SplitButton Name="SaveButton"
                                                        Grid.Column="1"
                                                        IsEnabled="{Binding Download.IsNotVerifyingUrl}"
                                                        HorizontalAlignment="Right"
                                                        Appearance="Primary"
                                                        Height="40"
                                                        FontSize="15"
                                                        FontWeight="Bold"
                                                        Icon="{ui:SymbolIcon Save24}"
                                                        Content="動画を保存"
                                                        Command="{Binding Download.SaveCommand}">
                                        <ui:SplitButton.Style>
                                            <Style TargetType="ui:SplitButton"
                                                   BasedOn="{StaticResource {x:Type ui:SplitButton}}">
                                                <Setter Property="Background"
                                                        Value="{DynamicResource AccentButtonBackground}" />
                                                <Setter Property="MouseOverBackground"
                                                        Value="{DynamicResource AccentButtonBackgroundPointerOver}" />
                                                <Setter Property="PressedBackground"
                                                        Value="{DynamicResource AccentButtonBackgroundPressed}" />
                                                <Setter Property="Foreground"
                                                        Value="{DynamicResource AccentButtonForeground}" />
                                                <Setter Property="PressedForeground"
                                                        Value="{DynamicResource AccentButtonForegroundPointerOver}" />
                                                <Setter Property="BorderBrush"
                                                        Value="{DynamicResource AccentControlElevationBorderBrush}" />
                                                <Setter Property="MouseOverBorderBrush"
                                                        Value="{DynamicResource AccentControlElevationBorderBrush}" />
                                                <Setter Property="PressedBorderBrush"
                                                        Value="{DynamicResource ControlFillColorTransparentBrush}" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsEnabled"
                                                             Value="False">
                                                        <!-- 文字・アイコン・矢印をすべて標準の無効時カラー（グレー）にする -->
                                                        <Setter Property="Foreground"
                                                                Value="{DynamicResource TextFillColorDisabledBrush}" />

                                                        <!-- 背景や境界線も無効時のグレー（または透明）にしておくと、より自然になります -->
                                                        <Setter Property="Background"
                                                                Value="{DynamicResource AccentButtonBackgroundDisabled}" />
                                                        <Setter Property="BorderBrush"
                                                                Value="{DynamicResource AccentButtonBorderBrushDisabled}" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ui:SplitButton.Style>
                                        <ui:SplitButton.Flyout>
                                                <ContextMenu>
                                                    <MenuItem Header="名前を指定して保存"
                                                              Command="{Binding Download.SaveAsCommand}" />
                                                </ContextMenu>
                                            </ui:SplitButton.Flyout>
                                        </ui:SplitButton>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </ui:Card>
                    </Grid>

                <!-- キュー一覧 -->
                <Grid Grid.Row="1" Margin="0,20,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="ダウンロードキュー"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                    <!-- キューが空の場合の表示 -->
                    <StackPanel Grid.Row="2"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Margin="0,60,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Download.QueueItems.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <ui:SymbolIcon Symbol="ArrowDownload24"
                                       FontSize="36"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,10" />
                        <TextBlock Text="キューに動画がありません。上のURL入力欄から追加してください。"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock HorizontalAlignment="Center" Margin="0,12,0,0">
                            <Hyperlink Click="FindSavedVideos_Click"
                                       Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                       TextDecorations="None">
                                保存した動画が見つかりませんか？
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>

                    <!-- キューリスト -->
                    <ItemsControl Grid.Row="2" ItemsSource="{Binding Download.QueueItems}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Download.QueueItems.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type services:DownloadItem}">
                                    <Border Margin="0,0,0,10">
                                        <ui:Card Padding="14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" /> <!-- アイコン -->
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />    <!-- タイトル / 保存先 / 進捗バー -->
                                                    <ColumnDefinition Width="15" />
                                                    <ColumnDefinition Width="Auto" /> <!-- キャンセルボタン -->
                                                </Grid.ColumnDefinitions>

                                                <!-- アイコン -->
                                                <ui:SymbolIcon Grid.Column="0"
                                                               FontSize="24"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               VerticalAlignment="Center">
                                                    <ui:SymbolIcon.Style>
                                                        <Style TargetType="ui:SymbolIcon">
                                                            <Setter Property="Symbol" Value="Video24" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsMp3}" Value="True">
                                                                    <Setter Property="Symbol" Value="MusicNote124" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ui:SymbolIcon.Style>
                                                </ui:SymbolIcon>

                                                <!-- タイトル / 保存先 / 進捗バー -->
                                                <Grid Grid.Column="2"
                                                      VerticalAlignment="Center">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <!-- タイトル -->
                                                    <TextBlock Grid.Row="0"
                                                               Text="{Binding Title}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding Title}"
                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                                                    <!-- ステータス -->
                                                    <TextBlock Grid.Row="1"
                                                               Text="{Binding StatusText}"
                                                               FontSize="11"
                                                               Margin="0,2,0,4"
                                                               TextTrimming="CharacterEllipsis"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                                                    <!-- 進捗バー -->
                                                    <ProgressBar Grid.Row="2"
                                                                 Height="4"
                                                                 Minimum="0"
                                                                 Maximum="100"
                                                                 Value="{Binding ProgressValue}"
                                                                 IsIndeterminate="{Binding IsProgressIndeterminate}"/>
                                                </Grid>

                                                <!-- キャンセルボタン -->
                                                <ui:Button Grid.Column="4"
                                                           Icon="{ui:SymbolIcon Dismiss24}"
                                                           Appearance="Secondary"
                                                           Command="{Binding CancelCommand}"
                                                           ToolTip="ダウンロードをキャンセル"
                                                           Width="32" Height="32"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </ui:Card>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
